<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#F4F6FB"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- NÚT BACK -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_revert"
        android:background="#663B82F6"
        android:contentDescription="Back" />

    <!-- TITLE -->
    <TextView
        android:text="MỤC TIÊU HỌC TẬP"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#222"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- CARD -->
    <LinearLayout
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="20dp"
        android:elevation="6dp"

        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- INPUT -->
        <EditText
            android:id="@+id/edtGoal"
            android:hint="Nhập số từ cần học..."
            android:textColor="@android:color/black"
            android:textColorHint="#888888"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- SAVE -->
        <Button
            android:id="@+id/btnSave"
            android:text="LƯU MỤC TIÊU"
            android:backgroundTint="#4A6CF7"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"

            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- HIỂN THỊ -->
        <TextView
            android:id="@+id/tvGoalToday"
            android:text="Mục tiêu hôm nay: --"
            android:textSize="18sp"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:textColor="@android:color/black"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvDone"
            android:text="Đã học 0/0 từ"
            android:textSize="16sp"
            android:layout_marginTop="5dp"
            android:layout_width="wrap_content"
            android:textColor="@android:color/black"
            android:layout_height="wrap_content"/>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:max="100"
            android:progress="30"
            android:progressTint="#4A6CF7"
            android:layout_marginTop="10dp"/>
        <TextView
            android:id="@+id/tvPercent"
            android:text="0%"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:layout_marginTop="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- NÚT HOME -->
        <Button
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quay về trang chủ"
            android:layout_marginTop="12dp"
            android:backgroundTint="#9CA3AF" />

    </LinearLayout>

</LinearLayout>